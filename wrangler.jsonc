{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "web-v3-site-10",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-20",
  "compatibility_flags": ["nodejs_compat_v2"],
  "account_id": "e3d03ee7c5ed3983dc29571829b2eb04",
  "workers_dev": true,
  "preview_urls": false,
  "triggers": {
    "crons": ["*/1 * * * *"]
  },
  "limits": {
    "cpu_ms": 300000,
    "subrequests": 10000
  },
  "observability": {
    "enabled": false
  },
  "placement": {
    "mode": "targeted",
    "hostname": "web-v3-site-10.99-e3d.workers.dev"
  },
  "vars": {
    "SANDBOX_TRANSPORT": "rpc",
    "API_KEY": "m9jeXyoL12OKSGqIoCwauEoPS6I31YNm9jCWohvLXsWQ2ipn",
    "REPORTER_ENDPOINT": "https://web-v3-site-10.99-e3d.workers.dev/instances/heartbeat"
  },
  "containers": [
    {
      "class_name": "MinerSandbox",
      "name": "miner-container",
      "image": "./Dockerfile",
      "instance_type": {
        "vcpu": 4,
        "memory_mib": 12288,
        "disk_mb": 20000
      },
      "max_instances": 375,
      "rollout_active_grace_period": 900,
      "rollout_step_percentage": 5,
      "constraints": {
        "tier": 1,
        "regions": [
          "APAC"
        ]
      }
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "MINER_COORDINATOR",
        "class_name": "MinerCoordinator"
      },
      {
        "name": "MINER_CONTAINER",
        "class_name": "MinerSandbox"
      }
    ]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "miner-metrics",
      "database_id": "67274855-5989-4ac0-b2f3-97ba28b1724f"
    }
  ],

  "analytics_engine_datasets": [
    {
      "binding": "HEARTBEATS",
      "dataset": "miner_heartbeats"
    }
  ],
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["MinerCoordinator", "MinerSandbox"]
    }
  ]
}
